# ──────────────────────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha as chaves reais.
# Nunca faça commit do .env — ele já está no .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ESRI ArcGIS API Key — https://developers.arcgis.com/
# Usado pelo globo 3D e mapa interativo
VITE_ESRI_API_KEY=

# Hugging Face API Token — https://huggingface.co/settings/tokens
# Usado pela página de detecção de objetos (DETR)
VITE_HUGGING_FACE_API_KEY=

# Supabase — https://app.supabase.com/ → Project Settings → API
# Usado pelo contador de visitas e chatBruno RAG
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Variáveis de Netlify Functions (definir no painel Netlify, não aqui)
# N8N_WEBHOOK_URL=  — endpoint do n8n self-hosted no AWS EC2
# ──────────────────────────────────────────────────────────────────────────────
